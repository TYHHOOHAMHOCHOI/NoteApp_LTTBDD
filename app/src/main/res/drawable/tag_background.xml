<?xml version="1.0" encoding="utf-8"?>
<!-- Nền bo tròn cho thẻ tag hiển thị trên item ghi chú -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- Màu nền nhạt của tag, dùng màu primary với độ trong suốt 20% -->
    <solid android:color="#1A6200EE" />
    <!-- Bo góc tròn -->
    <corners android:radius="12dp" />
    <!-- Viền mỏng màu primary -->
    <stroke
        android:width="1dp"
        android:color="@color/primary" />
</shape>
