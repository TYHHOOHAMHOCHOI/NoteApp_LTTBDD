<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/card_color"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <EditText
                    android:id="@+id/etNoteTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="Tiêu đề"
                    android:inputType="textMultiLine"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="24dp"
                    android:paddingBottom="4dp"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary" />

                <!-- Ô nhập tag cho ghi chú -->
                <EditText
                    android:id="@+id/etNoteTag"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="#tag (ví dụ: công việc, học tập...)"
                    android:inputType="text"
                    android:maxLines="1"
                    android:imeOptions="actionDone"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:textColorHint="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvCharCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="16dp"
                    android:text="0 ký tự"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvReminderInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="12dp"
                    android:text="Nhắc lúc: --"
                    android:textColor="#950000"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <EditText
                    android:id="@+id/etNoteContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="400dp"
                    android:background="@null"
                    android:gravity="top|start"
                    android:hint="Nội dung ghi chú..."
                    android:inputType="textMultiLine"
                    android:paddingHorizontal="0dp"
                    android:paddingTop="0dp"
                    android:paddingBottom="40dp"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary" />
            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:id="@+id/llRecordBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/stroke_light"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvRecordStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nhấn Play để ghi âm..."
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnStartRecord"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_autoplay"
                app:tint="@color/text_primary" />

            <ImageButton
                android:id="@+id/btnStopRecord"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_autostop"
                app:tint="@color/text_primary" />

            <ImageButton
                android:id="@+id/btnCloseRecord"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/text_primary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@color/bg_color"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageButton
                android:id="@+id/btnAddInNote"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Add in note"
                android:padding="14dp"
                android:src="@drawable/ic_add_in_note"
                app:tint="@color/text_primary" />

            <ImageButton
                android:id="@+id/btnAlign"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Align options"
                android:padding="14dp"
                android:src="@drawable/ic_align"
                app:tint="@color/text_primary" />

            <ImageButton
                android:id="@+id/btnTextSetting"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Text settings"
                android:padding="14dp"
                android:src="@drawable/ic_text_setting"
                app:tint="@color/text_primary" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/flPanelContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone">

            <include
                android:id="@+id/panelAlign"
                layout="@layout/bottom_sheet_align"
                android:visibility="gone" />

            <include
                android:id="@+id/panelTextSetting"
                layout="@layout/bottom_sheet_text_setting"
                android:visibility="gone" />

            <include
                android:id="@+id/panelNoteAction"
                layout="@layout/bottom_sheet_note_action"
                android:visibility="gone" />

        </FrameLayout>

    </LinearLayout>

    <RelativeLayout
        android:id="@+id/rlDrawingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="@color/card_color"
        android:elevation="10dp">

        <com.example.noteapp_lttbdd.DrawingView
            android:id="@+id/drawingView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@+id/llDrawingControls" />

        <LinearLayout
            android:id="@+id/llDrawingControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="horizontal"
            android:background="@color/stroke_light"
            android:padding="12dp">

            <Button
                android:id="@+id/btnDrawingClose"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Đóng"
                android:backgroundTint="#9E9E9E" />

            <Button
                android:id="@+id/btnDrawingClear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Xóa"
                android:backgroundTint="#F44336" />

            <Button
                android:id="@+id/btnDrawingDone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Hoàn tất"
                android:backgroundTint="#4CAF50" />
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>
