<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/card_color">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvNoteTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@+id/ivPinIcon"
                android:ellipsize="end"
                android:maxLines="1"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:text="Title" />

            <!-- MỚI: Thêm icon cho trạng thái ghim ghi chú -->
            <ImageView
                android:id="@+id/ivPinIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_toStartOf="@id/ivLockIcon"
                android:layout_marginEnd="4dp"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_pin"
                android:visibility="gone"
                app:tint="@color/primary" />

            <ImageView
                android:id="@+id/ivLockIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_secure"
                android:visibility="gone"
                app:tint="@color/primary" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tvNoteContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:maxLines="3"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:text="Content" />

        <TextView
            android:id="@+id/tvItemReminderInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="⏰ Nhắc lúc: --"
            android:textColor="#950000"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- Hiển thị tag của ghi chú, ẩn đi nếu tag trống -->
        <TextView
            android:id="@+id/tvNoteTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textSize="12sp"
            android:textColor="@color/primary"
            android:background="@drawable/tag_background"
            android:visibility="gone"
            android:text="#tag" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
